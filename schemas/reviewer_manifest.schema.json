{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bahman2017/tdf-product-artifact-builder/schemas/reviewer_manifest.schema.json",
  "title": "TDF Reviewer Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "product_id",
    "package_type",
    "builder_version",
    "entries",
    "engine_hardcoded",
    "simulation_authorized",
    "wet_lab_ready",
    "openmm_execution",
    "lammps_execution"
  ],
  "properties": {
    "manifest_version": { "type": "string", "const": "1.0" },
    "product_id": { "type": "string", "minLength": 1 },
    "package_type": { "type": "string", "const": "reviewer_package" },
    "builder_version": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_path", "sha256", "size_bytes"],
        "properties": {
          "relative_path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "engine_hardcoded": { "type": "boolean", "const": false },
    "simulation_authorized": { "type": "boolean", "const": false },
    "wet_lab_ready": { "type": "boolean", "const": false },
    "openmm_execution": { "type": "boolean", "const": false },
    "lammps_execution": { "type": "boolean", "const": false }
  }
}
