{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bahman2017/tdf-product-artifact-builder/schemas/evidence_manifest.schema.json",
  "title": "TDF Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "product_id",
    "evidence_count",
    "entries",
    "diagnostic_flags",
    "simulation_authorized",
    "wet_lab_ready"
  ],
  "properties": {
    "manifest_version": { "type": "string", "const": "1.0" },
    "product_id": { "type": "string", "minLength": 1 },
    "evidence_count": { "type": "integer", "minimum": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "source_tool",
          "source_version",
          "evidence_type",
          "sha256"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "source_tool": { "type": "string", "minLength": 1 },
          "source_version": { "type": "string", "minLength": 1 },
          "evidence_type": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "diagnostic_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lammps_input_executed",
        "simulation_executed",
        "accepted_for_simulation",
        "force_field_ready",
        "wet_lab_ready"
      ],
      "properties": {
        "lammps_input_executed": { "type": "boolean", "const": false },
        "simulation_executed": { "type": "boolean", "const": false },
        "accepted_for_simulation": { "type": "boolean", "const": false },
        "force_field_ready": { "type": "boolean", "const": false },
        "wet_lab_ready": { "type": "boolean", "const": false }
      }
    },
    "simulation_authorized": { "type": "boolean", "const": false },
    "wet_lab_ready": { "type": "boolean", "const": false }
  }
}
